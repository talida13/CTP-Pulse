# Copiază acest fișier în .env și completează valorile reale

# Google Maps Places API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# tranzy.ai GTFS real-time
TRANZY_API_URL=https://api.tranzy.ai/v1/opendata
TRANZY_API_KEY=your_tranzy_api_key_here

# Interval polling GTFS (secunde)
GTFS_POLL_INTERVAL=30

# Linii CTP de urmărit (separate prin virgulă)
CTP_LINES=1,3,7,8,13,28,43,46

# Cale output date
DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
DATA_GTFS_PATH=data/gtfs
